generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserOfferType {
  NEW_USER_UNLOCK
}

enum UserOfferState {
  ACTIVE
  EXPIRED
  CONSUMED
  INELIGIBLE
}

enum UserPaymentGatewayPreference {
  AUTO
  STRIPE
  TELEGRAM_STARS
  NOWPAYMENTS
}

enum BlockReason {
  ABUSE_PROMPT    // Prompt 滥用检测
  ABUSE_IMAGE     // 图片滥用检测  
  FRAUD_EFW       // Stripe 早期欺诈预警
  USER_REQUESTED  // 用户主动删除
  ADMIN_MANUAL    // 管理员手动封禁
}

enum AffiliateEarningSourceType {
  ORDER_PAYMENT
  SUBSCRIPTION_RENEWAL
}

enum AffiliateEarningState {
  PENDING
  AVAILABLE
  VOIDED
}

enum AffiliateCurrency {
  USD
}

enum AffiliateLedgerKind {
  EARNING_CREATED
  EARNING_MATURED
  PAYOUT_REQUESTED
  PAYOUT_RELEASED
  PAYOUT_COMPLETED
  EXCHANGE_CREDITS
  EARNING_VOIDED
  EARNING_RESTORED
  ADJUSTMENT
}

enum AffiliateLedgerReferenceType {
  EARNING
  PAYOUT_REQUEST
  PAYMENT
  INVOICE
  ADMIN
}

enum AffiliatePayoutType {
  CASHOUT_USDT
  EXCHANGE_CREDITS
}

enum AffiliatePayoutStatus {
  REQUESTED
  APPROVED
  REJECTED
  COMPLETED
  FAILED
}

model Account {
  id                       String  @id @default(cuid())
  userId                   String  @map("user_id")
  type                     String
  provider                 String
  providerAccountId        String  @map("provider_account_id")
  refresh_token            String?
  access_token             String?
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String?
  session_state            String?
  refresh_token_expires_in Int?
  user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Conversation {
  id                  String        @id @default(cuid())
  userId              String?       @map("user_id")
  projectId           String?       @map("project_id")
  isGuest             Boolean       @default(false) @map("is_guest")
  isArchived          Boolean       @default(false) @map("is_archived")
  isShared            Boolean       @default(false) @map("is_shared")
  sharedAt            DateTime?     @map("shared_at")
  title               String?
  metadata            Json?
  activeInteractionId String?       @map("active_interaction_id")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")
  project             Project?        @relation(fields: [projectId], references: [id])
  user                User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  interactions        Interaction[]
  supportTickets      SupportTicket[]

  @@index([updatedAt])
  @@index([userId, createdAt])
  @@index([isGuest, createdAt])
  @@index([userId, isArchived])
  @@index([isShared])
  @@index([projectId])
  @@index([userId, projectId])
  @@map("conversations")
}

model Interaction {
  id             String        @id @default(cuid())
  conversationId String        @map("conversation_id")
  userAgentId    String?       @map("user_agent_id")
  type           String
  parts          Json          @default("[]")
  metadata       Json?
  correlationId  String?       @map("correlation_id")
  parentId       String?       @map("parent_id")
  createdAt      DateTime      @default(now()) @map("created_at")
  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  parent         Interaction?  @relation("InteractionTree", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children       Interaction[] @relation("InteractionTree")
  userAgent      UserAgent?    @relation(fields: [userAgentId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([correlationId])
  @@index([userAgentId])
  @@index([parentId])
  @@map("interactions")
}

model Post {
  id          Int      @id @default(autoincrement())
  name        String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById String   @map("created_by_id")
  createdBy   User     @relation(fields: [createdById], references: [id])

  @@index([name])
  @@map("posts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id                       String                       @id @default(cuid())
  name                     String?
  email                    String?                      @unique
  emailVerified            DateTime?                    @map("email_verified")
  image                    String?
  timezone                 String?                      @default("UTC")
  countryCode              String?                      @map("country_code") // ISO 3166-1 alpha-2, e.g. "US", "DE"
  countryCodeSource        String?                      @map("country_code_source") // "AUTO" | "IP"
  countryCodeUpdatedAt     DateTime?                    @map("country_code_updated_at")
  isAdmin                  Boolean                      @default(false) @map("is_admin")
  utmCampaign              String?                      @map("utm_campaign")
  utmContent               String?                      @map("utm_content")
  utmMedium                String?                      @map("utm_medium")
  utmSource                String?                      @map("utm_source")
  utmTerm                  String?                      @map("utm_term")
  emailBounced             Boolean                      @default(false) @map("email_bounced")
  emailComplained          Boolean                      @default(false) @map("email_complained")
  createdAt                DateTime                     @default(now()) @map("created_at")
  isBlocked                Boolean                      @default(false) @map("is_blocked")
  blockedReason            BlockReason?                 @map("blocked_reason")
  blockedAt                DateTime?                    @map("blocked_at")
  canonicalEmail           String?                      @unique @map("canonical_email")
  hasPurchased             Boolean                      @default(false) @map("has_purchased")
  deviceKeyAtSignup        String?                      @map("device_key_at_signup")
  isPrimaryDeviceAccount   Boolean                      @default(true) @map("is_primary_device_account")
  stripeCustomerId         String?                      @map("stripe_customer_id")
  telegramId               String?                      @unique @map("telegram_id") // Telegram user ID for Stars payment
  paymentGatewayPreference UserPaymentGatewayPreference @default(AUTO) @map("payment_gateway_preference")
  signupIp                 String?                      @map("signup_ip")
  passwordHash             String?                      @map("password_hash")

  // Affiliate / Referral
  referralCode       String?   @unique @map("referral_code")
  referredById       String?   @map("referred_by_id")
  payoutWallet       String?   @map("payout_wallet")
  affiliateEnabledAt DateTime? @map("affiliate_enabled_at")

  referredBy User?  @relation("UserReferral", fields: [referredById], references: [id], onDelete: SetNull)
  referrals  User[] @relation("UserReferral")

  affiliateEarnings       AffiliateEarning[]       @relation("AffiliateUser")
  referredEarnings        AffiliateEarning[]       @relation("ReferredUser")
  affiliatePayoutRequests AffiliatePayoutRequest[]
  affiliateAccount        AffiliateAccount?
  affiliateLedgerEntries  AffiliateLedgerEntry[]

  // Ad Tracking
  adClickId       String?   @map("ad_click_id") // Stores gclid, gbraid, wbraid
  adClickProvider String?   @map("ad_click_provider") // e.g., "google"
  adClickTime     DateTime? @map("ad_click_time") // When the click happened

  accounts             Account[]
  activationCodes      ActivationCode[]
  conversations        Conversation[]
  documents            Document[]
  githubConnections    GitHubConnection?
  githubRepositories   GitHubRepository[]
  imageAssets          ImageAsset[]
  orders               Order[]               @relation("UserOrders")
  payments             Payment[]             @relation("UserPayments")
  posts                Post[]
  projects             Project[]
  sessions             Session[]
  userAgents           UserAgent[]
  stats                UserStats?
  offers               UserOffer[]
  attribution          UserAttribution?
  touchSchedules            TouchSchedule[]
  supportTickets            SupportTicket[]
  notificationPreferences   UserNotificationPreference[]
  @@index([createdAt])
  @@index([deviceKeyAtSignup, createdAt])
  @@index([utmSource])
  @@index([isBlocked])
  @@index([isPrimaryDeviceAccount])
  @@index([hasPurchased])
  @@index([signupIp])
  @@index([referredById])
  @@index([referralCode])
  @@map("users")
}

model AffiliateAccount {
  id             String            @id @default(uuid())
  userId         String            @unique @map("user_id")
  currency       AffiliateCurrency @default(USD)
  pendingCents   Int               @default(0) @map("pending_cents")
  availableCents Int               @default(0) @map("available_cents")
  lockedCents    Int               @default(0) @map("locked_cents")
  debtCents      Int               @default(0) @map("debt_cents")
  version        Int               @default(0)
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  user          User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  ledgerEntries AffiliateLedgerEntry[]

  @@index([updatedAt])
  @@map("affiliate_accounts")
}

model AffiliateLedgerEntry {
  id             String                       @id @default(uuid())
  accountId      String                       @map("account_id")
  userId         String                       @map("user_id")
  currency       AffiliateCurrency            @default(USD)
  kind           AffiliateLedgerKind
  referenceType  AffiliateLedgerReferenceType @map("reference_type")
  referenceId    String?                      @map("reference_id")
  idempotencyKey String                       @unique @map("idempotency_key")

  deltaPendingCents   Int @default(0) @map("delta_pending_cents")
  deltaAvailableCents Int @default(0) @map("delta_available_cents")
  deltaLockedCents    Int @default(0) @map("delta_locked_cents")
  deltaDebtCents      Int @default(0) @map("delta_debt_cents")

  meta      Json?    @map("meta")
  createdAt DateTime @default(now()) @map("created_at")

  account AffiliateAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([accountId, createdAt])
  @@index([userId, createdAt])
  @@index([referenceType, referenceId])
  @@map("affiliate_ledger_entries")
}

model AffiliateEarning {
  id               String                     @id @default(uuid())
  sourceType       AffiliateEarningSourceType @map("source_type")
  sourceExternalId String                     @map("source_external_id")
  sourceSequence   Int                        @default(0) @map("source_sequence")

  affiliateUserId String @map("affiliate_user_id")
  referredUserId  String @map("referred_user_id")

  orderId        String? @map("order_id")
  paymentId      String? @map("payment_id")
  subscriptionId String? @map("subscription_id")
  paymentGateway String? @map("payment_gateway")

  currency          AffiliateCurrency @default(USD)
  grossAmountCents  Int               @map("gross_amount_cents")
  commissionRateBps Int               @default(3000) @map("commission_rate_bps")
  commissionCents   Int               @map("commission_cents")

  state       AffiliateEarningState @default(PENDING)
  availableAt DateTime              @map("available_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  affiliateUser User @relation("AffiliateUser", fields: [affiliateUserId], references: [id], onDelete: Cascade)
  referredUser  User @relation("ReferredUser", fields: [referredUserId], references: [id], onDelete: Cascade)

  @@unique([sourceType, sourceExternalId, sourceSequence])
  @@index([affiliateUserId, state])
  @@index([affiliateUserId, availableAt])
  @@index([referredUserId])
  @@map("affiliate_earnings")
}

model AffiliatePayoutRequest {
  id              String @id @default(uuid())
  affiliateUserId String @map("affiliate_user_id")

  type   AffiliatePayoutType
  status AffiliatePayoutStatus @default(REQUESTED)

  currency    AffiliateCurrency @default(USD)
  amountCents Int               @map("amount_cents")

  // For cashout
  walletAddress String? @map("wallet_address")
  chain         String  @default("polygon")
  token         String  @default("usdt")
  txHash        String? @map("tx_hash")

  // Ops
  adminNote String? @map("admin_note")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  affiliateUser User @relation(fields: [affiliateUserId], references: [id], onDelete: Cascade)

  @@index([affiliateUserId, status])
  @@index([affiliateUserId, type, status])
  @@map("affiliate_payout_requests")
}

model UserAttribution {
  id           String   @id @default(cuid())
  userId       String   @unique @map("user_id")
  firstTouchAt DateTime @default(now()) @map("first_touch_at")

  // First touch landing info (privacy-friendly)
  landingPath String? @map("landing_path")
  refHost     String? @map("ref_host")
  refType     String? @map("ref_type") // "search" | "referral" | "direct" | "unknown"
  channel     String? @map("channel") // "organic_search" | "paid_search" | "referral" | "direct" | "unknown"

  // Snapshot of attribution params at first touch
  utmSource   String? @map("utm_source")
  utmMedium   String? @map("utm_medium")
  utmCampaign String? @map("utm_campaign")
  utmTerm     String? @map("utm_term")
  utmContent  String? @map("utm_content")
  adClickId   String? @map("ad_click_id")
  adClickProv String? @map("ad_click_provider")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([firstTouchAt])
  @@index([channel])
  @@index([refHost])
  @@map("user_attributions")
}

model UserOffer {
  id         String         @id @default(cuid())
  userId     String         @map("user_id")
  type       UserOfferType
  state      UserOfferState @default(ACTIVE)
  source     String?
  variant    String?
  startedAt  DateTime?      @map("started_at")
  endsAt     DateTime?      @map("ends_at")
  consumedAt DateTime?      @map("consumed_at")
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([type, state])
  @@index([userId])
  @@index([endsAt])
  @@map("user_offers")
}

model UserStats {
  id                   String    @id @default(cuid())
  userId               String    @unique @map("user_id")
  totalPaidCents       Int       @default(0) @map("total_paid_cents")
  ordersCount          Int       @default(0) @map("orders_count")
  firstPaidAt          DateTime? @map("first_paid_at")
  lastPaidAt           DateTime? @map("last_paid_at")
  hasUsedProTrial      Boolean   @default(false) @map("has_used_pro_trial")
  proTrialSource       String?   @map("pro_trial_source")
  proTrialConverted    Boolean   @default(false) @map("pro_trial_converted")
  hitPaywallCount      Int       @default(0) @map("hit_paywall_count")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_stats")
}

model GitHubConnection {
  id             String   @id @default(cuid())
  userId         String   @unique @map("user_id")
  githubUserId   String   @map("github_user_id")
  githubUsername String   @map("github_username")
  accessToken    String   @map("access_token")
  scope          String
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("github_connections")
}

model GitHubRepository {
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  owner         String
  name          String
  fullName      String    @map("full_name")
  url           String
  defaultBranch String    @default("main") @map("default_branch")
  isPrivate     Boolean   @default(false) @map("is_private")
  description   String?
  language      String?
  indexStatus   String    @default("pending") @map("index_status")
  indexedAt     DateTime? @map("indexed_at")
  lastSyncedAt  DateTime? @map("last_synced_at")
  metadata      Json?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects      Project[]

  @@unique([userId, owner, name])
  @@index([userId])
  @@index([userId, indexStatus])
  @@index([fullName])
  @@map("github_repositories")
}

model Agent {
  id           String      @id @default(cuid())
  name         String
  description  String?
  instructions String
  model        String      @default("google/gemini-2.5-pro")
  avatar       String?
  color        String?
  tools        String[]    @default([])
  enabled      Boolean     @default(true)
  isSystem     Boolean     @default(false) @map("is_system")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  userAgents   UserAgent[]

  @@index([isSystem, enabled])
  @@map("agents")
}

model UserAgent {
  id                 String        @id @default(cuid())
  userId             String        @map("user_id")
  agentId            String        @map("agent_id")
  isDefault          Boolean       @default(false) @map("is_default")
  enabled            Boolean       @default(true)
  customInstructions String?       @map("custom_instructions")
  customModel        String?       @map("custom_model")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")
  interactions       Interaction[]
  agent              Agent         @relation(fields: [agentId], references: [id], onDelete: Cascade)
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, agentId])
  @@index([userId])
  @@index([userId, isDefault])
  @@index([agentId])
  @@map("user_agents")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model ImageAsset {
  id           String       @id @default(cuid())
  userId       String       @map("user_id")
  agentId      String?      @map("agent_id")
  projectId    String?      @map("project_id")
  storageKey   String       @unique @map("storage_key")
  imageUrl     String       @map("image_url")
  thumbnailUrl String?      @map("thumbnail_url")
  contentType  String       @default("image/png") @map("content_type")
  fileSize     Int?         @map("file_size")
  width        Int?
  height       Int?
  type         String       @default("generate")
  prompt       String
  model        String       @default("doubao-seedream-4-0-250828")
  parentId     String?      @map("parent_id")
  size         String?
  ratio        String?
  watermark    Boolean      @default(false)
  status       String       @default("completed")
  error        String?
  tags         String[]     @default([])
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  parent       ImageAsset?  @relation("ImageVersions", fields: [parentId], references: [id])
  children     ImageAsset[] @relation("ImageVersions")
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([projectId, createdAt])
  @@index([parentId])
  @@index([prompt])
  @@map("image_assets")
}

model ActivationCode {
  id         String    @id @default(cuid())
  code       String    @unique
  userId     String    @map("user_id")
  createdBy  String    @map("created_by")
  assignedTo String?   @map("assigned_to")
  status     String    @default("unused")
  usedBy     String?   @map("used_by")
  usedAt     DateTime? @map("used_at")
  projectId  String?   @map("project_id")
  expiresAt  DateTime? @map("expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([userId])
  @@index([code])
  @@map("activation_codes")
}

model Project {
  id                 String               @id @default(cuid())
  userId             String               @map("user_id")
  name               String
  description        String?
  status             String               @default("active")
  metadata           Json?
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")
  githubRepositoryId String?              @map("github_repository_id")
  conversations      Conversation[]
  documents          Document[]
  imageAssets        ImageAsset[]
  qualityScore       ProjectQualityScore?
  githubRepository   GitHubRepository?    @relation(fields: [githubRepositoryId], references: [id])
  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([userId, status])
  @@index([githubRepositoryId])
  @@map("projects")
}

model Document {
  id          String     @id @default(cuid())
  projectId   String     @map("project_id")
  userId      String     @map("user_id")
  title       String
  content     String
  fileUrl     String?    @map("file_url")
  fileType    String?    @map("file_type")
  fileSize    Int?       @map("file_size")
  status      String     @default("active")
  metadata    Json?
  version     Int        @default(1)
  isCurrent   Boolean    @default(true) @map("is_current")
  contentHash String?    @map("content_hash")
  parentId    String?    @map("parent_id")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  parent      Document?  @relation("DocumentVersions", fields: [parentId], references: [id])
  children    Document[] @relation("DocumentVersions")
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([userId])
  @@index([projectId, title, isCurrent])
  @@index([projectId, title, version])
  @@index([parentId])
  @@map("documents")
}

model ProjectQualityScore {
  id         String   @id @default(cuid())
  projectId  String   @unique @map("project_id")
  totalScore Int
  confidence String
  metrics    Json
  stats      Json?
  version    Int      @default(1)
  scoredAt   DateTime @default(now()) @map("scored_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([scoredAt])
  @@index([totalScore])
  @@map("project_quality_scores")
}

model Product {
  id                  String                      @id @default(uuid())
  name                String
  description         Json?
  price               Int                         // USD price in cents (default/fallback)
  originalPrice       Int                         @default(0) @map("original_price")
  currency            String                      @default("usd") // Default currency (kept for backward compatibility)
  type                ProductType
  interval            String?
  status              ProductStatus               @default(ACTIVE)
  isAvailable         Boolean                     @default(true) @map("is_available")
  sortOrder           Int                         @default(0) @map("sort_order")
  metadata            Json?
  createdAt           DateTime                    @default(now()) @map("created_at")
  updatedAt           DateTime                    @updatedAt @map("updated_at")
  deletedAt           DateTime?                   @map("deleted_at")
  hasTrial            Boolean                     @default(false) @map("has_trial")
  trialCreditsAmount  Int?                        @map("trial_credits_amount")
  trialDays           Int?                        @map("trial_days")
  orders              Order[]
  creditsPackage      ProductCreditsPackage?
  oneTimeEntitlements ProductOneTimeEntitlement[]
  productSubscription ProductSubscription?
  prices              ProductPrice[]              // Multi-currency prices

  @@index([status, isAvailable, deletedAt])
  @@index([type, status, deletedAt])
  @@map("products")
}

// Multi-currency pricing for international markets
