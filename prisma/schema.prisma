// ============================================================================
// Support System - AI 客服助理
// ============================================================================

enum SupportTicketStatus {
  OPEN           // 待处理 (Initial state)
  NEEDS_APPROVAL // 待审核 (AI proposed draft/action)
  WAITING        // 待回复 (Waiting for customer)
  SOLVED         // 已解决 (Done)
}

enum SupportActorType {
  USER   // 客户
  AI     // 模型
  AGENT  // 人工
  SYSTEM // 系统
}

enum SupportEventType {
  MESSAGE // 实际发生的对话 (Email, Chat)
  DRAFT   // 拟定的回复/操作 (Internal only)
  ACTION  // 工具调用 (Refund, Cancel, etc.)
  NOTE    // 内部备注
  SYSTEM  // 状态变更日志
}

model SupportTicket {
  id String @id @default(uuid())

  // 1. 客户身份
  userId  String? @map("user_id")
  contact String  @map("contact") // email or handle
  channel String  @default("email")

  // 2. 状态机
  status     SupportTicketStatus @default(OPEN)
  assignedTo SupportActorType    @default(AI) @map("assigned_to")

  // 3. 上下文
  subject  String?
  summary  String? @db.Text
  priority Int     @default(0) // 0:Normal, 1:High, 2:Urgent

  // 4. 渠道绑定（用于投影到外部系统）
  feishuThreadId String? @map("feishu_thread_id") // 飞书话题 ID

  // 5. AI 对话上下文（复用 ai-chat 的 Conversation）
  conversationId String?       @map("conversation_id")
  conversation   Conversation? @relation(fields: [conversationId], references: [id])

  // 6. 统计
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  resolvedAt DateTime? @map("resolved_at")

  timeline SupportTimeline[]
  user     User?             @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status, assignedTo])
  @@index([contact])
  @@index([feishuThreadId])
  @@map("support_tickets")
}

model SupportTimeline {
  id       String @id @default(uuid())
  ticketId String @map("ticket_id")

  // 1. 主体
  actor   SupportActorType
  actorId String?          @map("actor_id") // userId if AGENT/USER

  // 2. 事件
  type    SupportEventType
  content String?          @db.Text // The message body, draft content, or action desc

  // 3. 元数据 (The "Everything Else" bucket)
  // DRAFT: { proposed_actions: [...], confidence: 0.8 }
  // MESSAGE (Email): { messageId, inReplyTo, cc }
  // ACTION: { tool_name, args, result }
  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
  @@index([ticketId, type])
  @@map("support_timeline")
}

model SupportSyncCursor {
  id        String   @id // e.g., "email_inbox"
  lastUid   Int      @default(0) @map("last_uid")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("support_sync_cursors")
}

