// ============================================================================
// Touch (Reach-out) / Notifications scheduling
// ============================================================================

enum TouchChannel {
  EMAIL
  SMS
  PUSH
}

enum TouchTriggerType {
  SCHEDULED // 定时触发
  EVENT     // 事件触发
  MANUAL    // 手动触发
}

enum TouchScheduleStatus {
  PENDING
  PROCESSING
  SENT
  CANCELLED
  SUPERSEDED
  FAILED
}

enum TouchRecordStatus {
  SENT
  DELIVERED
  DELIVERY_DELAYED
  BOUNCED
  COMPLAINED
  OPENED
  CLICKED
  FAILED
}

// 触达场景（Campaign）- 定义触达的业务场景
model TouchScene {
  id          String           @id @default(uuid())
  key         String           @unique // e.g. "sub_renewal_d1", "welcome_email"
  name        String
  description String?
  channel     TouchChannel     @default(EMAIL)
  triggerType TouchTriggerType @default(SCHEDULED) @map("trigger_type")
  isActive    Boolean          @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  templates TouchTemplate[]
  schedules TouchSchedule[]

  @@index([key, isActive])
  @@map("touch_scenes")
}

// 触达模板 - 场景下的具体内容模板（支持多语言/多版本/A-B测试）
model TouchTemplate {
  id       String @id @default(uuid())
  sceneKey String @map("scene_key")

  locale    String  @default("en") // en, zh, ja, etc.
  version   String  @default("default") // default, v2, variant_a, etc.
  isDefault Boolean @default(false) @map("is_default")
  isActive  Boolean @default(true) @map("is_active")

  // 邮件模板内容
  subject  String?
  bodyText String? @map("body_text")
  bodyHtml String? @map("body_html")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  scene   TouchScene    @relation(fields: [sceneKey], references: [key], onDelete: Cascade)
  records TouchRecord[]

  @@unique([sceneKey, locale, version])
  @@index([sceneKey, isActive, isDefault])
  @@map("touch_templates")
}

// 触达计划 - 待发送的具体任务
model TouchSchedule {
  id      String       @id @default(uuid())
  userId  String       @map("user_id")
  channel TouchChannel

  // 关联场景
  sceneKey String?     @map("scene_key")
  scene    TouchScene? @relation(fields: [sceneKey], references: [key])

  referenceType String @map("reference_type")
  referenceId   String @map("reference_id")

  // Idempotency / dedupe
  dedupeKey String @unique @map("dedupe_key")

  timezone      String?             @map("timezone")
  scheduledAt   DateTime            @map("scheduled_at")
  nextAttemptAt DateTime            @map("next_attempt_at")
  status        TouchScheduleStatus @default(PENDING)

  attemptCount Int       @default(0) @map("attempt_count")
  maxAttempts  Int       @default(5) @map("max_attempts")
  lockedAt     DateTime? @map("locked_at")
  lockId       String?   @map("lock_id")
  lastError    String?   @map("last_error")

  payload Json? @map("payload")

  sentAt       DateTime? @map("sent_at")
  cancelledAt  DateTime? @map("cancelled_at")
  supersededAt DateTime? @map("superseded_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  records TouchRecord[]

  @@index([sceneKey])
  @@index([status, nextAttemptAt])
  @@index([referenceType, referenceId])
  @@index([userId, createdAt])
  @@map("touch_schedules")
}

// 触达日志 - 发送记录
model TouchRecord {
  id            String @id @default(uuid())
  scheduleId    String @map("schedule_id")
  attemptNumber Int    @map("attempt_number")

  // 使用的模板
  templateId String? @map("template_id")

  provider          String  @default("resend") @map("provider")
  providerMessageId String? @map("provider_message_id")
  toEmail           String  @map("to_email")
  subject           String? @map("subject")

  status TouchRecordStatus
  error  String?           @map("error")
  meta   Json?             @map("meta")

  occurredAt DateTime @default(now()) @map("occurred_at")
  createdAt  DateTime @default(now()) @map("created_at")

  schedule TouchSchedule  @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  template TouchTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@unique([scheduleId, attemptNumber])
  @@unique([provider, providerMessageId])
  @@index([scheduleId, occurredAt])
  @@index([templateId])
  @@map("touch_records")
}

