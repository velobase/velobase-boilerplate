// Immutable cashflow facts for analytics & reconciliation.
// - Append-only: do NOT update rows; add new rows for refunds/disputes.
// - Use (gateway, externalId) as idempotency key to support safe replays/backfills.
model PaymentTransaction {
  id                    String   @id @default(uuid())
  gateway               String
  externalId            String   @map("external_id") // invoice id / payment_intent id / charge id
  kind                  String   // e.g. ONE_OFF_CHARGE, SUBSCRIPTION_INITIAL_CHARGE, SUBSCRIPTION_RENEWAL_CHARGE, REFUND, DISPUTE
  amount                Int      // in smallest unit (cents)
  currency              String   @default("usd")
  userId                String?  @map("user_id")
  orderId               String?  @map("order_id")
  paymentId             String?  @map("payment_id")
  gatewaySubscriptionId String?  @map("gateway_subscription_id")
  gatewayInvoiceId      String?  @map("gateway_invoice_id")
  gatewayChargeId       String?  @map("gateway_charge_id")
  gatewayPaymentIntentId String? @map("gateway_payment_intent_id")
  occurredAt            DateTime @map("occurred_at") // gateway-side occurrence time
  sourceEventId         String?  @map("source_event_id")
  sourceEventType       String?  @map("source_event_type")
  createdAt             DateTime @default(now()) @map("created_at") // inserted-at time

  @@unique([gateway, externalId])
  @@index([userId])
  @@index([occurredAt])
  @@index([gatewaySubscriptionId])
  @@index([gatewayInvoiceId])
  @@index([gatewayChargeId])
  @@index([gatewayPaymentIntentId])
  @@index([orderId])
  @@index([paymentId])
  @@map("payment_transactions")
}

