model UserSubscriptionCycle {
  id                    String                      @id @default(uuid())
  subscriptionId        String                      @map("subscription_id")
  paymentId             String?                     @map("payment_id")
  // 幂等键：用于防止并发/重复履约导致重复创建 cycle（不依赖 paymentId 语义）
  // - 首期/Trial：建议使用 `pay_${paymentId}`
  // - Stripe 续费：建议使用 `stripe_invoice_${txnId}` 或 `sub_renewal_${subscriptionId}_${txnId}`
  uniqueKey             String?                     @unique @map("unique_key")
  type                  UserSubscriptionCycleType   @default(UNDEFINED)
  status                UserSubscriptionCycleStatus @default(UNDEFINED)
  sequenceNumber        Int                         @default(1) @map("sequence_number")
  startsAt              DateTime                    @map("starts_at")
  expiresAt             DateTime                    @map("expires_at")
  lastCreditGrantAnchor DateTime?                   @map("last_credit_grant_anchor")
  createdAt             DateTime                    @default(now()) @map("created_at")
  updatedAt             DateTime                    @updatedAt @map("updated_at")
  deletedAt             DateTime?                   @map("deleted_at")
  subscription          UserSubscription            @relation(fields: [subscriptionId], references: [id])

  @@unique([subscriptionId, sequenceNumber])
  @@index([subscriptionId])
  @@index([paymentId])
  @@index([uniqueKey])
  @@index([lastCreditGrantAnchor])
  @@map("membership_user_subscription_cycles")
}

